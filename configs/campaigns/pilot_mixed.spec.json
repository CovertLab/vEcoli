{
    "name": "pilot_mixed",
    "description": "Mixed pilot: noise sweep + real datasets + Annabelle exclusions + both overlays",
    "source_dataset_id": "vecoli_m9_glucose_minus_aas",
    "operator": "add_log_normal_noise",
    "param_grid": {
        "sigma": [0.1, 0.2, 0.4, 0.8],
        "seed": [0]
    },
    "include_source_as_baseline": true,
    "extra_dataset_ids": [
        "precise_control:wt_glc",
        "precise_abx_media:m9_ctrl",
        "precise_abx_media:m9_ctrl_no_TRPpwy",
        "precise_ica:wt_glc",
        "gbw_vegas_wt_m9glc_34h_no_ssrA",
        "gbw_vegas_wt_m9glc_34h_no_ssrA_no_CYSpwy",
        "gbw_bermuda_ctrl",
        "gbw_bermuda_ctrl_no_ssrA"
    ],
    "base_config": "configs/test_multi_parca.json",
    "sim": {
        "generations": 3,
        "n_init_sims": 3,
        "analysis_options": {
            "single": { "mass_fraction_summary": {} },
            "multigeneration": {
                "ribosome_components": {},
                "ribosome_production": {},
                "ribosome_usage": {}
            },
            "multiseed": { "cd1_higher_order_properties": {} },
            "multivariant": {
                "sensitivity_overview": {
                    "campaign_sidecar": "configs/campaigns/pilot_mixed.campaign.json"
                },
                "doubling_time_line": {},
                "doubling_time_hist": {},
                "cell_mass": {}
            }
        }
    }
}
