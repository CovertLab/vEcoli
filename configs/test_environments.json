{
    "experiment_id": "test_environments",
    "suffix_time": false,
    "parca_options": {
        "cpus": 16
    },
    "fail_at_max_duration": true,
    "sim_data_path": null,
    "generations": 8,
    "n_init_sims": 8,
    "single_daughters": true,
    "emitter": "parquet",
    "emitter_arg": {
        "out_dir": "out"
    },
    "variants": {
        "uptake_constraints": {
            "condition": {
                "value": ["basal", "acetate", "succinate"]
            },
            "carbon_source_rate": {
                "linspace": {"start": 0, "stop": 20, "num": 4}
            },
            "o2_rate": {
                "linspace": {"start": 0, "stop": 20, "num": 4}
            },
            "op": "prod"
        }
    },
    "analysis_options": {
        "single": {"mass_fraction_summary": {}},
        "multivariant": {"doubling_time_line": {}},
        "multigeneration": {"ribosome_usage": {}}
    }
}
