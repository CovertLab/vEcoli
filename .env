# Use single thread for BLAS for better performance and reproducibility
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
VECLIB_MAXIMUM_THREADS=1

# Data sources for RNA-seq ingestion (used by wholecell.io.ingestion).
# Sourced by the container entrypoint (/entrypoint.sh) on every task start.
# Primary manifest: synced from ecoli-sources via `aws s3 sync`
ECOLI_SOURCES=s3://smsvpctest-shared-sharedbucket60d199d6-abfvwv0day91/sources/ecoli-sources
# Overlay manifests (private datasets): semicolon-separated, URI-safe
ECOLI_SOURCES_OVERLAYS=s3://smsvpctest-shared-sharedbucket60d199d6-abfvwv0day91/sources/ecoli-sources-vegas/data/manifest.tsv;s3://smsvpctest-shared-sharedbucket60d199d6-abfvwv0day91/sources/ecoli-sources-bermuda/data/manifest.tsv
