{
    "steps": [
    {
        "name": "gcr.io/cloud-builders/docker",
        "args": [
            "build",
            "--build-arg", "from=${LOCATION}-docker.pkg.dev/${PROJECT_ID}/vecoli/${_RUNTIME_IMAGE}",
            "--build-arg", "git_hash=${_GIT_HASH}",
            "--build-arg", "git_branch=${_GIT_BRANCH}",
            "--build-arg", "timestamp=${_TIMESTAMP}",
            "-t", "${LOCATION}-docker.pkg.dev/${PROJECT_ID}/vecoli/${_CODE_IMAGE}",
            "-f", "runscripts/container/wholecell/Dockerfile",
            "."
        ]
    }
    ],
    "images": [
        "${LOCATION}-docker.pkg.dev/${PROJECT_ID}/vecoli/${_CODE_IMAGE}"
    ]
}
