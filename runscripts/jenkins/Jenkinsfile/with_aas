pipeline {
    agent any

    triggers {
        cron('H H * * *')
    }

    options {
        skipDefaultCheckout(true)
    }

    stages {
        stage('Checkout') {
            steps {
                checkout([
                    $class: 'GitSCM',
                    branches: scm.branches,
                    extensions: [
                        [$class: 'CloneOption', depth: 1, noTags: false, shallow: true, reference: '', honorRefspec: true]
                    ],
                    userRemoteConfigs: scm.userRemoteConfigs
                ])
            }
        }

        stage('Run Pipeline') {
            steps {
                script {
                    def standardPipeline = load 'runscripts/jenkins/Jenkinsfile/standardPipeline.groovy'
                    standardPipeline.run(
                        stageName: 'With AAs',
                        timeout: '12h',
                        commands: 'sh runscripts/jenkins/workflow.sh runscripts/jenkins/configs/ecoli-with-aa.json',
                        outputDir: '/scratch/groups/mcovert/vecoli/jenkins_with_aa',
                        keepCount: 20
                    )
                }
            }
        }
    }
}
